---
import { siteConfig } from '../../data/config';
---

<section id="section-explorer" class="editor-section section-enter" style="min-height: 100vh; padding-bottom: 0;">
  <div class="editor-with-lines">
    <div class="line-numbers" aria-hidden="true">
      {Array.from({ length: 42 }, (_, i) => (
        <span class="ln">{i + 1}</span>
      ))}
    </div>
    <div class="editor-lines">

      <!-- Line 1-3: file header comment -->
      <div class="code-line"><span class="token-comment">/**</span></div>
      <div class="code-line"><span class="token-comment"> * README.md — {siteConfig.name}</span></div>
      <div class="code-line"><span class="token-comment"> */</span></div>
      <div class="code-line">&nbsp;</div>

      <!-- Line 5: const name -->
      <div class="code-line">
        <span class="token-keyword">const</span>
        <span> </span>
        <span class="token-variable">developer</span>
        <span class="token-operator"> = </span>
        <span class="token-punct">{"{"}</span>
      </div>

      <!-- Properties -->
      <div class="code-line" style="padding-left: 2ch;">
        <span class="token-property">name</span>
        <span class="token-operator">: </span>
        <span class="token-string">"{siteConfig.name}"</span>
        <span class="token-punct">,</span>
      </div>
      <div class="code-line" style="padding-left: 2ch;">
        <span class="token-property">role</span>
        <span class="token-operator">: </span>
        <span class="token-string">"{siteConfig.role}"</span>
        <span class="token-punct">,</span>
      </div>
      <div class="code-line" style="padding-left: 2ch;">
        <span class="token-property">location</span>
        <span class="token-operator">: </span>
        <span class="token-string">"{siteConfig.location}"</span>
        <span class="token-punct">,</span>
      </div>
      <div class="code-line" style="padding-left: 2ch;">
        <span class="token-property">available</span>
        <span class="token-operator">: </span>
        <span class="token-constant">true</span>
        <span class="token-punct">,</span>
      </div>
      <div class="code-line">
        <span class="token-punct">{"}"}</span>
        <span class="token-punct">;</span>
      </div>
      <div class="code-line">&nbsp;</div>

      <!-- Hero name display -->
      <div style="padding: 32px 0 24px 0;">
        <h1 class="hero-name">
          <span class="token-function">{siteConfig.name}</span>
        </h1>
        <p class="hero-role">
          <span class="token-operator">// </span>
          <span class="token-comment">{siteConfig.role}</span>
        </p>
        <p class="hero-tagline">{siteConfig.tagline}</p>
      </div>

      <!-- CTA buttons -->
      <div class="hero-ctas">
        <a
          href="#section-projects"
          class="cta-primary"
          onclick="document.getElementById('section-projects')?.scrollIntoView({behavior:'smooth'}); return false;"
        >
          <span class="token-keyword">view</span>
          <span class="token-punct">(</span>
          <span class="token-string">"projects"</span>
          <span class="token-punct">)</span>
        </a>
        <a
          href={siteConfig.github}
          target="_blank"
          rel="noopener noreferrer"
          class="cta-secondary"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
          GitHub
        </a>
      </div>

      <div class="code-line" style="margin-top: 48px;">&nbsp;</div>
      <div class="code-line"><span class="token-comment">// Press Ctrl+K to open command palette</span></div>
      <div class="code-line"><span class="token-comment">// Navigate sections from the sidebar or tabs ↑</span></div>

    </div>
  </div>
</section>

<style>
.hero-name {
  font-family: var(--font-mono);
  font-size: var(--text-3xl);
  font-weight: 700;
  line-height: 1.1;
  color: var(--vsc-syntax-function);
  letter-spacing: -0.02em;
  margin-bottom: 8px;
}

.hero-role {
  font-family: var(--font-mono);
  font-size: var(--text-lg);
  margin-bottom: 12px;
}

.hero-tagline {
  font-family: var(--font-ui);
  font-size: var(--text-lg);
  color: var(--vsc-text-secondary);
  margin-bottom: 0;
  max-width: 500px;
  line-height: 1.6;
}

.hero-ctas {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 28px;
}

.cta-primary {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 8px 20px;
  background: var(--vsc-accent);
  color: white;
  font-family: var(--font-mono);
  font-size: var(--text-base);
  border-radius: 4px;
  text-decoration: none;
  transition: background 0.15s ease;
}

.cta-primary:hover {
  background: var(--vsc-accent-hover);
  text-decoration: none;
}

.cta-secondary {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 20px;
  background: transparent;
  color: var(--vsc-text-primary);
  font-family: var(--font-mono);
  font-size: var(--text-base);
  border-radius: 4px;
  border: 1px solid var(--vsc-border);
  text-decoration: none;
  transition: border-color 0.15s ease, background 0.15s ease;
}

.cta-secondary:hover {
  border-color: var(--vsc-text-secondary);
  background: var(--vsc-bg-hover);
  text-decoration: none;
}

.code-line {
  font-family: var(--font-mono);
  font-size: var(--text-md);
  line-height: var(--line-height-editor);
  color: var(--vsc-text-primary);
  white-space: nowrap;
}
</style>
