---
import { experiences } from '../../data/experience';
---

<section id="section-git" class="editor-section section-enter" style="min-height: 50vh; border-top: 1px solid var(--vsc-border);">
  <div class="editor-with-lines">
    <div class="line-numbers" aria-hidden="true">
      {Array.from({ length: 40 }, (_, i) => (
        <span class="ln">{i + 160}</span>
      ))}
    </div>
    <div class="editor-lines">
      <div class="code-line"><span class="token-comment"># CHANGELOG.md — Experience & Timeline</span></div>
      <div class="code-line">&nbsp;</div>
      <div class="code-line"><span class="token-comment">## git log --pretty=format:"%h %s" --author="Vu Huy Hoang"</span></div>
      <div class="code-line">&nbsp;</div>

      <div class="git-log">
        {experiences.map((exp, i) => (
          <div class="git-entry section-enter" style={`animation-delay: ${i * 0.1}s`}>
            <div class="git-left">
              <div class="git-dot" class:list={[exp.type]}></div>
              {i < experiences.length - 1 && <div class="git-line"></div>}
            </div>
            <div class="git-content">
              <div class="git-hash">
                <span class="token-constant">
                  {Math.random().toString(36).slice(2, 9)}
                </span>
                <span class="git-date">{exp.date}</span>
              </div>
              <div class="git-subject">
                <span class="token-string">{exp.company}</span>
                <span class="token-operator"> — </span>
                <span class="token-function">{exp.role}</span>
              </div>
              <p class="git-body">{exp.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
.git-log {
  margin-top: 12px;
  padding-left: 4px;
}

.git-entry {
  display: flex;
  gap: 16px;
  margin-bottom: 4px;
}

.git-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 16px;
  flex-shrink: 0;
  padding-top: 4px;
}

.git-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: var(--vsc-accent);
  border: 2px solid var(--vsc-bg-editor);
  box-shadow: 0 0 0 1px var(--vsc-accent);
  flex-shrink: 0;
  z-index: 1;
}

.git-dot.education {
  background: var(--vsc-syntax-class);
  box-shadow: 0 0 0 1px var(--vsc-syntax-class);
}

.git-line {
  flex: 1;
  width: 2px;
  background: var(--vsc-border);
  margin: 4px 0;
  min-height: 32px;
}

.git-content {
  flex: 1;
  padding-bottom: 24px;
}

.git-hash {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 4px;
}

.git-date {
  font-family: var(--font-mono);
  font-size: var(--text-xs);
  color: var(--vsc-text-muted);
}

.git-subject {
  font-family: var(--font-mono);
  font-size: var(--text-md);
  line-height: 1.5;
  margin-bottom: 6px;
}

.git-body {
  font-family: var(--font-ui);
  font-size: var(--text-sm);
  color: var(--vsc-text-secondary);
  line-height: 1.6;
  max-width: 580px;
}

.code-line {
  font-family: var(--font-mono);
  font-size: var(--text-md);
  line-height: var(--line-height-editor);
}
</style>
