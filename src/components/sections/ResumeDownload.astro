---
// Resume download section
// Replace /resume.pdf with the actual resume file path when available

const resumeHref = 'resume.pdf';
---

<section id="section-resume" class="editor-section section-enter" style="border-top: 1px solid var(--vsc-border); padding-bottom: 80px;">
  <div class="editor-with-lines">
    <div class="line-numbers" aria-hidden="true">
      {Array.from({ length: 12 }, (_, i) => (
        <span class="ln">{i + 200}</span>
      ))}
    </div>
    <div class="editor-lines">
      <div class="code-line"><span class="token-comment"># Download Resume</span></div>
      <div class="code-line">&nbsp;</div>

      <div class="resume-terminal">
        <div class="code-line">
          <span class="term-prompt">$</span>
          <span class="token-function"> curl</span>
          <span class="token-string"> -O</span>
          <span class="token-variable"> resume.pdf</span>
        </div>
        <div class="code-line" style="margin-top: 6px; color: var(--vsc-text-secondary);">
          <span class="token-comment">  % Total    % Received  Xferd  Average Speed</span>
        </div>
        <div class="code-line" style="color: var(--vsc-git-added);">
          <span class="token-comment">  100  42K   100  42K   0     0   890k      0 --:--:-- --:--:-- 100%</span>
        </div>
      </div>

      <div class="resume-actions">
        <a
          href={resumeHref}
          download="VuHuyHoang_Resume.pdf"
          class="resume-btn primary"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          <span class="token-keyword">curl</span>
          <span class="token-punct"> -O </span>
          <span class="token-string">VuHuyHoang_Resume.pdf</span>
        </a>
        <a
          href="https://github.com/0372hoanghoccode"
          target="_blank"
          rel="noopener noreferrer"
          class="resume-btn secondary"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
          View GitHub Profile
        </a>
      </div>

      <div class="code-line" style="margin-top: 16px;">
        <span class="token-comment">// Note: Resume will be updated with latest experience</span>
      </div>
    </div>
  </div>
</section>

<style>
.resume-terminal {
  padding: 12px 16px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--vsc-border);
  border-radius: 4px;
  margin: 12px 0 20px 0;
  max-width: 520px;
}

.resume-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.resume-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  border-radius: 4px;
  font-family: var(--font-mono);
  font-size: var(--text-base);
  text-decoration: none;
  transition: all 0.15s ease;
}

.resume-btn.primary {
  background: var(--vsc-accent);
  color: white;
  border: 1px solid var(--vsc-accent);
}

.resume-btn.primary:hover {
  background: var(--vsc-accent-hover);
  text-decoration: none;
}

.resume-btn.secondary {
  background: transparent;
  color: var(--vsc-text-primary);
  border: 1px solid var(--vsc-border);
}

.resume-btn.secondary:hover {
  border-color: var(--vsc-text-secondary);
  background: var(--vsc-bg-hover);
  text-decoration: none;
}

.term-prompt {
  color: var(--vsc-accent-green);
  font-weight: 600;
  margin-right: 4px;
}

.code-line {
  font-family: var(--font-mono);
  font-size: var(--text-md);
  line-height: var(--line-height-editor);
}
</style>
