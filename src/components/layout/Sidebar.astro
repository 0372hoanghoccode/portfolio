---
interface Props {
  activeSection?: string;
}
const { activeSection = 'explorer' } = Astro.props;

const fileTree = [
  {
    folder: 'PORTFOLIO',
    open: true,
    items: [
      { id: 'explorer', label: 'README.md',     icon: 'md',   section: 'explorer' },
      { id: 'projects', label: 'projects/',      icon: 'folder', section: 'projects' },
      { id: 'skills',   label: 'package.json',  icon: 'json', section: 'skills' },
      { id: 'git',      label: 'CHANGELOG.md',  icon: 'md',   section: 'git' },
      { id: 'contact',  label: 'terminal',       icon: 'term', section: 'contact' },
    ]
  }
];

const projectFiles = [
  { label: 'movie-chill.md',      icon: 'md',   git: 'M' },
  { label: 'tour-management.md',  icon: 'md',   git: 'M' },
  { label: 'social-micro.md',     icon: 'md',   git: 'M' },
];
---

<aside class="sidebar" id="sidebar" role="complementary" aria-label="File Explorer">
  <div class="sidebar-header">Explorer</div>
  <div class="sidebar-tree">
    {fileTree.map(folder => (
      <div class="sidebar-section">
        <div class="sidebar-section-header open" data-folder={folder.folder}>
          <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
          </svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="color: #dcb67a; flex-shrink:0;">
            <path d="M19.5 21a3 3 0 0 0 3-3v-4.5a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3V18a3 3 0 0 0 3 3h15ZM1.5 10.146V6a3 3 0 0 1 3-3h5.379a2.25 2.25 0 0 1 1.59.659l2.122 2.121c.14.141.333.22.53.22H19.5a3 3 0 0 1 3 3v1.146A4.483 4.483 0 0 0 19.5 9h-15a4.483 4.483 0 0 0-3 1.146Z" />
          </svg>
          <span>{folder.folder}</span>
        </div>

        {folder.items.map(item => (
          <div>
            <button
              class={`sidebar-item${activeSection === item.id ? ' active' : ''}`}
              data-section={item.section}
              type="button"
            >
              {/* File icon */}
              {item.icon === 'md' && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="color: #519aba;">
                  <path fill-rule="evenodd" d="M5.625 1.5H9a3.75 3.75 0 0 1 3.75 3.75v1.875c0 1.036.84 1.875 1.875 1.875H16.5a3.75 3.75 0 0 1 3.75 3.75v7.875c0 1.035-.84 1.875-1.875 1.875H5.625a1.875 1.875 0 0 1-1.875-1.875V3.375c0-1.036.84-1.875 1.875-1.875ZM9.75 17.25a.75.75 0 0 0-1.5 0V21a.75.75 0 0 0 1.5 0v-3.75Zm3-3a.75.75 0 0 0-1.5 0V21a.75.75 0 0 0 1.5 0v-6.75Zm3 3a.75.75 0 0 0-1.5 0V21a.75.75 0 0 0 1.5 0v-3.75Z" clip-rule="evenodd" />
                </svg>
              )}
              {item.icon === 'folder' && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="color: #dcb67a;">
                  <path d="M19.5 21a3 3 0 0 0 3-3v-4.5a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3V18a3 3 0 0 0 3 3h15Z" />
                </svg>
              )}
              {item.icon === 'json' && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="color: #cbcb41;">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z"/>
                </svg>
              )}
              {item.icon === 'term' && (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: #4ec9b0;">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" />
                </svg>
              )}
              <span>{item.label}</span>
            </button>

            {/* Nested project files */}
            {item.id === 'projects' && (
              <div class="sidebar-nested" id="projects-nested">
                {projectFiles.map(pf => (
                  <button class="sidebar-item" style="padding-left: 40px;" data-section="projects" type="button">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="color: #519aba;">
                      <path fill-rule="evenodd" d="M5.625 1.5H9a3.75 3.75 0 0 1 3.75 3.75v1.875c0 1.036.84 1.875 1.875 1.875H16.5a3.75 3.75 0 0 1 3.75 3.75v7.875c0 1.035-.84 1.875-1.875 1.875H5.625a1.875 1.875 0 0 1-1.875-1.875V3.375c0-1.036.84-1.875 1.875-1.875Z" clip-rule="evenodd" />
                    </svg>
                    <span>{pf.label}</span>
                    <span class="git-badge" style={`color: ${pf.git === 'M' ? 'var(--vsc-git-modified)' : 'var(--vsc-git-added)'}`}>{pf.git}</span>
                  </button>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    ))}
  </div>
</aside>

<div class="sidebar-overlay" id="sidebar-overlay"></div>

<script>
  // Sidebar item navigation
  document.querySelectorAll<HTMLButtonElement>('.sidebar-item[data-section]').forEach(item => {
    item.addEventListener('click', () => {
      const section = item.dataset.section;
      if (!section) return;

      // Close mobile sidebar
      document.getElementById('sidebar')?.classList.remove('open');
      document.getElementById('sidebar-overlay')?.classList.remove('visible');

      // Update active states
      document.querySelectorAll('.sidebar-item').forEach(i => i.classList.remove('active'));
      item.classList.add('active');

      // Scroll to section in editor
      const target = document.getElementById(`section-${section}`);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // Sync activity bar
      document.querySelectorAll('.activity-bar-item[data-section]').forEach(b => {
        b.classList.toggle('active', (b as HTMLElement).dataset.section === section);
      });
    });
  });

  // Mobile sidebar overlay click to close
  document.getElementById('sidebar-overlay')?.addEventListener('click', () => {
    document.getElementById('sidebar')?.classList.remove('open');
    document.getElementById('sidebar-overlay')?.classList.remove('visible');
  });

  // Folder toggle
  document.querySelectorAll<HTMLElement>('.sidebar-section-header').forEach(header => {
    header.addEventListener('click', () => {
      header.classList.toggle('open');
    });
  });
</script>
