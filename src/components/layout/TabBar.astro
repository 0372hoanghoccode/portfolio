---
interface Props {
  activeSection?: string;
}
const { activeSection = 'explorer' } = Astro.props;

const tabs = [
  { id: 'explorer', label: 'README.md',    icon: 'md'   },
  { id: 'projects', label: 'projects/',    icon: 'folder' },
  { id: 'skills',   label: 'package.json', icon: 'json' },
  { id: 'git',      label: 'CHANGELOG.md', icon: 'md'   },
  { id: 'contact',  label: 'terminal',     icon: 'term' },
];
---

<div class="tab-bar" role="tablist" aria-label="Open Files">
  <!-- Mobile menu toggle -->
  <button
    class="tab mobile-sidebar-toggle"
    id="mobile-menu-btn"
    style="border-right: 1px solid var(--vsc-border); padding: 0 12px; flex-shrink: 0;"
    aria-label="Toggle file explorer"
    type="button"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
    </svg>
  </button>

  {tabs.map(tab => (
    <button
      class={`tab${activeSection === tab.id ? ' active' : ''}`}
      data-section={tab.id}
      role="tab"
      aria-selected={activeSection === tab.id}
      type="button"
    >
      {/* Icon */}
      {tab.icon === 'md' && (
        <svg class="tab-icon" viewBox="0 0 24 24" fill="currentColor" style="color: #519aba;">
          <path fill-rule="evenodd" d="M5.625 1.5H9a3.75 3.75 0 0 1 3.75 3.75v1.875c0 1.036.84 1.875 1.875 1.875H16.5a3.75 3.75 0 0 1 3.75 3.75v7.875c0 1.035-.84 1.875-1.875 1.875H5.625a1.875 1.875 0 0 1-1.875-1.875V3.375c0-1.036.84-1.875 1.875-1.875Z" clip-rule="evenodd" />
        </svg>
      )}
      {tab.icon === 'folder' && (
        <svg class="tab-icon" viewBox="0 0 24 24" fill="currentColor" style="color: #dcb67a;">
          <path d="M19.5 21a3 3 0 0 0 3-3v-4.5a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3V18a3 3 0 0 0 3 3h15Z" />
        </svg>
      )}
      {tab.icon === 'json' && (
        <svg class="tab-icon" viewBox="0 0 24 24" fill="currentColor" style="color: #cbcb41;">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
        </svg>
      )}
      {tab.icon === 'term' && (
        <svg class="tab-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color: #4ec9b0;">
          <path stroke-linecap="round" stroke-linejoin="round" d="m6.75 7.5 3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0 0 21 18V6a2.25 2.25 0 0 0-2.25-2.25H5.25A2.25 2.25 0 0 0 3 6v12a2.25 2.25 0 0 0 2.25 2.25Z" />
        </svg>
      )}
      <span>{tab.label}</span>
      <span class="tab-close" aria-hidden="true">×</span>
    </button>
  ))}
</div>

<script>
  // Tab click navigation
  document.querySelectorAll<HTMLButtonElement>('.tab[data-section]').forEach(tab => {
    tab.addEventListener('click', () => {
      const section = tab.dataset.section;
      if (!section) return;

      document.querySelectorAll('.tab[data-section]').forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      const target = document.getElementById(`section-${section}`);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      // Sync sidebar + activity bar
      document.querySelectorAll('.sidebar-item[data-section]').forEach(item => {
        item.classList.toggle('active', (item as HTMLElement).dataset.section === section);
      });
      document.querySelectorAll('.activity-bar-item[data-section]').forEach(b => {
        b.classList.toggle('active', (b as HTMLElement).dataset.section === section);
      });
    });

    // Stop tab-close from triggering tab navigation (cosmetic only)
    tab.querySelector('.tab-close')?.addEventListener('click', e => {
      e.stopPropagation();
    });
  });

  // Mobile menu toggle
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    sidebar?.classList.toggle('open');
    overlay?.classList.toggle('visible');
  });
</script>
